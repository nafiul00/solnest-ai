# Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Claude model (valid: claude-opus-4-6, claude-sonnet-4-5, claude-haiku-4-5-20251001)
CLAUDE_MODEL=claude-sonnet-4-5

# Gmail SMTP settings for sending reports
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
REPORT_TO_EMAIL=your-email@gmail.com

# Schedule (cron format) - default: Monday 8:00 AM
CRON_SCHEDULE=0 8 * * 1

# PriceLabs URL
PRICELABS_URL=https://app.pricelabs.co/pricing
