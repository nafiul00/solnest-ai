# Revenue Intel — Environment Variables
# Copy this to .env and fill in your values.

# Claude API (required)
ANTHROPIC_API_KEY=sk-ant-...

# Gmail SMTP — for weekly email reports (required)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
REPORT_TO_EMAIL=your-email@gmail.com

# PriceLabs (required for Phase 1)
PRICELABS_URL=https://app.pricelabs.co/pricing

# Python Revenue Engine (required)
PYTHON_ENGINE_URL=http://localhost:5050

# Schedule — cron format (optional, defaults shown)
DAILY_CRON=0 7 * * *
WEEKLY_CRON=0 8 * * 1

# Claude model for orchestrator analysis (optional)
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Phase 2: Hospitable API ─────────────────────────
# Personal Access Token from https://developer.hospitable.com/
HOSPITABLE_PAT=

# ─── Phase 3: Airbnb Competitor Data (Apify) ─────────
# Get your token from https://console.apify.com/account/integrations
APIFY_TOKEN=

# ─── Phase 5: Slack Daily Alerts ─────────────────────
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
