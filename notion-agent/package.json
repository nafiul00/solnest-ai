{
  "name": "notion-agent",
  "version": "1.0.0",
  "description": "Notion integration — pushes property metrics, weekly reports, and guest logs to client Notion workspaces",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "setup": "node setup.js",
    "sync": "node index.js --run-now",
    "sync:weekly": "node index.js --run-now --weekly"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3"
  }
}
