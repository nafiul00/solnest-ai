# ============================================================
# Guest Agent — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- Server ---
PORT=3000

# --- Hospitable API ---
HOSPITABLE_PAT=your_personal_access_token
HOSPITABLE_WEBHOOK_SECRET=your_webhook_secret

# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
# Optional: override model (defaults to claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# --- Slack Alerts ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --- WhatsApp Alerts (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886
HOST_WHATSAPP_NUMBER=+12505551234

# --- Email Alerts (Gmail) ---
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
HOST_EMAIL=host@example.com
