# ─────────────────────────────────────────────────────────────────────────────
# Solnest AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# This is the SINGLE .env for the entire platform.
# All sub-systems (cortex-backend, guest-agent, revenue-intel, etc.) load from here.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Anthropic (Claude AI) ───────────────────────────────────────────────────
# Required by: cortex-backend, guest-agent, revenue-intel
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Claude model to use (default: claude-sonnet-4-6)
# Options: claude-sonnet-4-6 | claude-haiku-4-5-20251001 | claude-opus-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Hospitable (STR platform — bookings, calendar, guest messages) ───────────
# Required by: cortex-backend, guest-agent
# Get from: https://app.hospitable.com → Settings → API → Personal Access Tokens
# Scopes: pat:read + pat:write
HOSPITABLE_PAT=eyJ0eXAiOiJKV1Qi...

# ─── Slack (Alerts & Escalations) ────────────────────────────────────────────
# Required by: guest-agent (escalation), revenue-intel (daily alerts)
# Get from: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ─── Gmail (Email Reports) ───────────────────────────────────────────────────
# Required by: revenue-intel (daily/weekly reports)
# Use App Password (not your main password): Google Account → Security → App Passwords
GMAIL_USER=hello@solneststays.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
REPORT_TO_EMAIL=your@email.com
HOST_EMAIL=your@email.com

# ─── Notion (Notion Agent) ───────────────────────────────────────────────────
# Required by: notion-agent
# Get from: https://www.notion.so/my-integrations → Create Integration
NOTION_TOKEN=ntn_...

# ─── Apify (Airbnb Competitor Scraping) ──────────────────────────────────────
# Required by: apify_trigger.py, revenue-intel
# Get from: https://console.apify.com → Settings → Integrations → API tokens
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Airbnb listing URLs to monitor (comma-separated)
LISTING_URLS=https://www.airbnb.com/rooms/YOUR_LISTING_ID

# ─── CORTEX Backend ──────────────────────────────────────────────────────────
# Port for cortex-backend Express server (default: 3001)
PORT=3001

# ─── CORTEX Dashboard (Vite) ─────────────────────────────────────────────────
# Set in cortex-dashboard/.env (must start with VITE_ for Vite to expose to browser)
# VITE_API_URL=http://localhost:3001

# ─── PriceLabs (Dynamic Pricing) ─────────────────────────────────────────────
# Required by: pricelabs-agent, revenue-intel
# Run setup: cd revenue-intel && node setup-auth.js --site pricelabs
PRICELABS_EMAIL=your@email.com
PRICELABS_PASSWORD=yourpassword

# ─── Schedule Overrides (cron format, America/Vancouver) ─────────────────────
# DAILY_CRON=0 7 * * *
# WEEKLY_CRON=0 8 * * 1

# ─── GoHighLevel (GHL) — Marketing CRM Pipeline (future) ─────────────────────
# Get from: https://marketplace.gohighlevel.com → My Apps → API Keys
# GHL_API_KEY=
# GHL_LOCATION_ID=
