# ─────────────────────────────────────────────────────────────────────────────
# Revenue Management Agent Project — Python Flask Engine
# Copy to .env — never commit .env to git
#
# Pure decision engine — no external API keys required.
# Called by the Next.js CRM app via /api/revenue-agent route.
#
# Start: python serve.py
# Test:  curl http://127.0.0.1:5050/health
# ─────────────────────────────────────────────────────────────────────────────

# Port the Flask HTTP bridge listens on
SERVE_PORT=5050

# Host to bind to
# 127.0.0.1 = localhost only (default — Next.js calls it on the same machine)
# 0.0.0.0   = all interfaces (use only if deploying to a separate server)
SERVE_HOST=127.0.0.1
